{
  "name": "@noble/curves",
  "version": "2.0.0-alpha",
  "description": "Audited & minimal JS implementation of elliptic curve cryptography",
  "files": [
    "*.js",
    "*.js.map",
    "*.d.ts",
    "*.d.ts.map",
    "esm",
    "src",
    "abstract"
  ],
  "scripts": {
    "bench": "npm run bench:install; cd benchmark; node secp256k1.js; node curves.js; node utils.js; node bls.js",
    "bench:install": "cd benchmark; npm install; npm install .. --install-links",
    "build": "tsc && tsc -p tsconfig.cjs.json",
    "build:release": "npx jsbt esbuild test/build",
    "build:clean": "rm {.,esm,abstract,esm/abstract}/*.{js,d.ts,d.ts.map,js.map} 2> /dev/null",
    "lint": "prettier --check 'src/**/*.{js,ts}' 'test/*.js'",
    "format": "prettier --write 'src/**/*.{js,ts}' 'test/*.js'",
    "test": "node test/index.js",
    "test:bun": "bun test/index.js",
    "test:deno": "deno --allow-env --allow-read test/index.js",
    "test:coverage": "npm install --no-save c8@10.1.2 && npx c8 npm test"
  },
  "author": "Paul Miller (https://paulmillr.com)",
  "homepage": "https://paulmillr.com/noble/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulmillr/noble-curves.git"
  },
  "license": "MIT",
  "dependencies": {
    "@noble/hashes": "file:noble-hashes-2.0.0-alpha.tgz"
  },
  "devDependencies": {
    "@paulmillr/jsbt": "0.3.3",
    "fast-check": "3.0.0",
    "micro-bmark": "0.4.0",
    "micro-should": "0.5.1",
    "prettier": "3.5.2",
    "typescript": "5.8.2"
  },
  "sideEffects": false,
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./cjs/index.js"
    },
    "./abstract/bls.js": {
      "import": "./abstract/bls.js",
      "require": "./cjs/abstract/bls.js"
    },
    "./abstract/curve.js": {
      "import": "./abstract/curve.js",
      "require": "./cjs/abstract/curve.js"
    },
    "./abstract/edwards.js": {
      "import": "./abstract/edwards.js",
      "require": "./cjs/abstract/edwards.js"
    },
    "./abstract/hash-to-curve.js": {
      "import": "./abstract/hash-to-curve.js",
      "require": "./cjs/abstract/hash-to-curve.js"
    },
    "./abstract/modular.js": {
      "import": "./abstract/modular.js",
      "require": "./cjs/abstract/modular.js"
    },
    "./abstract/montgomery.js": {
      "import": "./abstract/montgomery.js",
      "require": "./cjs/abstract/montgomery.js"
    },
    "./abstract/poseidon.js": {
      "import": "./abstract/poseidon.js",
      "require": "./cjs/abstract/poseidon.js"
    },
    "./abstract/tower.js": {
      "import": "./abstract/tower.js",
      "require": "./cjs/abstract/tower.js"
    },
    "./abstract/utils.js": {
      "import": "./abstract/utils.js",
      "require": "./cjs/abstract/utils.js"
    },
    "./abstract/weierstrass.js": {
      "import": "./abstract/weierstrass.js",
      "require": "./cjs/abstract/weierstrass.js"
    },
    "./_shortw_utils.js": {
      "import": "./_shortw_utils.js",
      "require": "./cjs/_shortw_utils.js"
    },
    "./bls12-381.js": {
      "import": "./bls12-381.js",
      "require": "./cjs/bls12-381.js"
    },
    "./bn254.js": {
      "import": "./bn254.js",
      "require": "./cjs/bn254.js"
    },
    "./ed448.js": {
      "import": "./ed448.js",
      "require": "./cjs/ed448.js"
    },
    "./ed25519.js": {
      "import": "./ed25519.js",
      "require": "./cjs/ed25519.js"
    },
    "./index.js": {
      "import": "./index.js",
      "require": "./cjs/index.js"
    },
    "./misc.js": {
      "import": "./misc.js",
      "require": "./cjs/misc.js"
    },
    "./p256.js": {
      "import": "./p256.js",
      "require": "./cjs/p256.js"
    },
    "./p384.js": {
      "import": "./p384.js",
      "require": "./cjs/p384.js"
    },
    "./p521.js": {
      "import": "./p521.js",
      "require": "./cjs/p521.js"
    },
    "./secp256k1.js": {
      "import": "./secp256k1.js",
      "require": "./cjs/secp256k1.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "elliptic",
    "curve",
    "cryptography",
    "secp256k1",
    "ed25519",
    "p256",
    "p384",
    "p521",
    "secp256r1",
    "ed448",
    "x25519",
    "ed25519",
    "bls12-381",
    "bn254",
    "alt_bn128",
    "bls",
    "noble",
    "ecc",
    "ecdsa",
    "eddsa",
    "weierstrass",
    "montgomery",
    "edwards",
    "schnorr"
  ],
  "funding": "https://paulmillr.com/funding/"
}
